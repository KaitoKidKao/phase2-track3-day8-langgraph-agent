---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__(<p>__start__</p>)
	intake(intake)
	classify(classify)
	answer(answer)
	tool(tool)
	evaluate(evaluate)
	clarify(clarify)
	risky_action(risky_action)
	approval(approval)
	retry(retry)
	dead_letter(dead_letter)
	research(research)
	rag(rag)
	reflection(reflection)
	finalize(finalize)
	__end__(<p>__end__</p>)
	__start__ --> intake;
	answer --> reflection;
	clarify --> finalize;
	classify -.-> answer;
	classify -.-> clarify;
	classify -.-> rag;
	classify -.-> research;
	classify -.-> retry;
	classify -.-> risky_action;
	classify -.-> tool;
	intake --> classify;
	rag --> evaluate;
	research --> evaluate;
	risky_action --> approval;
	tool --> evaluate;
	approval --> __end__;
	evaluate --> __end__;
	finalize --> __end__;
	reflection --> __end__;
	retry --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
